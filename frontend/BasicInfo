<body>

<h2>Employee Performance Evaluation</h2>

<input id="attendance" placeholder="Attendance %" />
<br>

<select id="quality">
    <option value="good">Good Quality</option>
    <option value="average">Average Quality</option>
    <option value="poor">Poor Quality</option>
</select>

<br>

<select id="punctuality">
    <option value="yes">Punctual</option>
    <option value="no">Not Punctual</option>
</select>

<br>

<button onclick="checkPerformance()">Evaluate</button>

<h3 id="result"></h3>

<script>
async function checkPerformance() {
    const data = {
        attendance: Number(document.getElementById("attendance").value),
        quality: document.getElementById("quality").value,
        punctuality: document.getElementById("punctuality").value
    };

    const res = await fetch("http://localhost:5000/evaluate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    });

    const result = await res.json();
    document.getElementById("result").innerText =
        "Performance: " + result.performance;
}
</script>

</body>
</html>
const express = require("express");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

// Expert System Rule Engine
function evaluateEmployee(data) {
    let score = 0;

    if (data.attendance >= 90) score += 3;
    else if (data.attendance >= 75) score += 2;
    else score += 1;

    if (data.quality === "good") score += 3;
    else if (data.quality === "average") score += 2;
    else score += 1;

    if (data.punctuality === "yes") score += 3;

    if (score >= 8) return "Excellent";
    else if (score >= 5) return "Good";
    else if (score >= 3) return "Average";
    else return "Poor";
}

// API
app.post("/evaluate", (req, res) => {
    const result = evaluateEmployee(req.body);
    res.json({ performance: result });
});

app.listen(5000, () => {
    console.log("Server running on port 5000");
});
